		JButton btnProximo = new JButton("proximo");
		btnProximo.addActionListener(new ActionListener() {
			public void actionPerformed(ActionEvent e) {

			    JSONObject pacienteAtual = null;

			    try {

			        JSONArray pacientes = consumo.buscar_paciente();

			        for (int i = 0; i < pacientes.size(); i++) {

			            JSONObject paciente = (JSONObject) pacientes.get(i);

			            // Ignora pacientes já atendidos
			            if ((boolean) paciente.get("atendido")) {
			                continue;
			            }

			            if (pacienteAtual == null) {

			                pacienteAtual = paciente;

			            } else {

			                if (consumo.prioridadeMaior(paciente, pacienteAtual)) {
			                    pacienteAtual = paciente;
			                }

			            }
			        }

			        // Depois que terminou o for, mostra o paciente escolhido
			        if (pacienteAtual != null) {

			            id.setText(pacienteAtual.get("id").toString());
			            nome.setText(pacienteAtual.get("nome").toString());
			            cpf.setText(pacienteAtual.get("cpf").toString());
			            idade.setText(pacienteAtual.get("idade").toString());
			            grau.setText(pacienteAtual.get("grauUrgencia").toString());
			            horario.setText(pacienteAtual.get("horarioChegada").toString());

			        } else {

			            JOptionPane.showMessageDialog(null, "Não há pacientes aguardando atendimento.");

			        }

			    } catch (Exception ex) {

			        ex.printStackTrace();

			    }

			}

				    
		});
		btnProximo.setBounds(142, 36, 135, 23);
